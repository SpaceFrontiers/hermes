          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Block coherence d at reorder",
      "description": "Measured d = postings/terms per (block,dim) \u2014 the Auto threshold input (default 4.0). Bimodal distribution with the threshold in the valley = well-tuned; mass near 3\u20136 = revisit BLOCKWISE_COHERENCE_THRESHOLD.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "x": 12,
        "y": 34,
        "w": 12,
        "h": 8
