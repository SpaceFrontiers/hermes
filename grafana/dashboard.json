          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Doc-map indirection lookups",
      "description": "Cost of virtual\u2192doc mapping (BP reorders only BMP-internal record order). If high while latency degrades under memory pressure, pin doc maps (HERMES_PIN_METADATA_BUDGET_MB).",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "x": 8,
        "y": 26,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
