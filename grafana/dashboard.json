          },
          "expr": "sum by (field) (rate(hermes_bmp_blocks_skipped_total{index=~\"$index\", namespace=\"$namespace\", pod=~\"$pod\"}[$__rate_interval])) / (sum by (field) (rate(hermes_bmp_blocks_scored_total{index=~\"$index\", namespace=\"$namespace\", pod=~\"$pod\"}[$__rate_interval])) + sum by (field) (rate(hermes_bmp_blocks_skipped_total{index=~\"$index\", namespace=\"$namespace\", pod=~\"$pod\"}[$__rate_interval])))",
          "legendFormat": "field {{field}}",
