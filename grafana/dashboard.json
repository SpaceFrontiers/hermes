          "expr": "histogram_quantile(0.5, sum by (le) (rate(hermes_search_duration_seconds_bucket{index=~\"$index\", namespace=\"$namespace\", pod=~\"$pod\"}[$__rate_interval])))",
          "legendFormat": "p50",
          "refId": "A",
          "range": true
