          "refId": "A",
          "range": true
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "histogram_quantile(0.95, sum by (le, field) (rate(hermes_bmp_docmap_lookups_per_query_bucket{index=~\"$index\", namespace=\"$namespace\", pod=~\"$pod\"}[$__rate_interval])))",
          "legendFormat": "p95/query field {{field}}",
          "refId": "B",
          "range": true
