      "id": 11,
      "type": "timeseries",
      "title": "Block skip ratio",
      "description": "",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "x": 16,
        "y": 18,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
