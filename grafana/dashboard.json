    {
      "id": 30,
      "type": "timeseries",
      "title": "Reorder granularity decisions",
      "description": "Per-pass Auto decisions (docs/block-level-reorder.md). Steady-state cascade should be mostly `blocks` (cheap superblock-locality recovery); persistent `records` on merged segments means sources are losing coherence.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "x": 0,
        "y": 34,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (granularity, field) (increase(hermes_reorder_granularity_total{index=~\"$index\", namespace=\"$namespace\", pod=~\"$pod\"}[$__interval]))",
          "legendFormat": "{{granularity}} field {{field}}",
          "refId": "A",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
