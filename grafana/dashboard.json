    {
      "id": 10,
      "type": "timeseries",
      "title": "Superblock skip ratio",
      "description": "Higher is better \u2014 fraction of superblocks pruned without scoring. Falls when segments lose BP ordering (run reorder / enable reorder_on_merge).",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "x": 8,
        "y": 18,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (field) (rate(hermes_bmp_superblocks_skipped_total{index=~\"$index\", namespace=\"$namespace\", pod=~\"$pod\"}[$__rate_interval])) / (sum by (field) (rate(hermes_bmp_superblocks_visited_total{index=~\"$index\", namespace=\"$namespace\", pod=~\"$pod\"}[$__rate_interval])) + sum by (field) (rate(hermes_bmp_superblocks_skipped_total{index=~\"$index\", namespace=\"$namespace\", pod=~\"$pod\"}[$__rate_interval])))",
          "legendFormat": "field {{field}}",
          "refId": "A",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 8,
            "showPoints": "never",
            "spanNulls": true
          },
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
